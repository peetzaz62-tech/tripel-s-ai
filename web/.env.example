# copy to .env.local (local dev) and set the same values in Vercel → Project → Settings → Environment Variables

# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # secret — server only, never expose

# RunPod (Console → Settings → API Keys / Serverless endpoint page)
RUNPOD_API_KEY=rpa_...
RUNPOD_ENDPOINT_ID=xxxxxxxxxx
